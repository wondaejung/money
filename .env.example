# ── 개인 대시보드 인증 (Vercel 배포 시 필수) ─────────────────
ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin
# 선택: 세션 서명용 비밀값 (미설정 시 ADMIN_PASSWORD 사용)
# SESSION_SECRET=random-long-string

# ── 포트폴리오 클라우드 동기화 (어떤 기기에서도 동일) ───────────
# Vercel Storage에서 Redis 연결 시 보통 REDIS_URL 하나만 자동 생성됩니다.
REDIS_URL=redis://default:password@host:6379
# 또는 Upstash REST 방식:
# UPSTASH_REDIS_REST_URL=your-upstash-rest-url
# UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ── 무료 LLM (추천) ──────────────────────────────────────────
# Groq: https://console.groq.com 에서 무료 API 키 발급
GROQ_API_KEY=gsk_your-groq-api-key
# 70b 모델은 TPD 한도가 빠르게 소진됩니다. 무료 tier는 8b instant 권장.
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODELS=gemma2-9b-it

# Google Gemini: https://aistudio.google.com/apikey 에서 무료 API 키 발급
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_FALLBACK_MODELS=gemini-2.0-flash-lite

# 로컬 Ollama (완전 무료, PC에서 ollama run llama3.2 필요)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# ── 유료 LLM ────────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# LLM_PROVIDER를 지정하지 않으면 설정된 키를 자동 감지합니다.
# 우선순위: Groq → Gemini → OpenAI → Anthropic → Ollama
